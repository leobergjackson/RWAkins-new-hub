      <!-- Purchase Coverage -->
      <div class="card-dark purchase-card reveal" id="purchase">
        <div class="purchase-header">
          <h3>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" fill="url(#payoutGrad)"/>
              <path d="M9 12l2 2 4-4" stroke="#0a0a0a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Get Covered
          </h3>
          <span class="badge badge-gold">ERC-5192</span>
        </div>

        <div class="form-group">
          <label class="form-label" for="issuerSelect">Select Issuer</label>
          <select class="form-select" id="issuerSelect" onchange="calculatePremium()">
            <option value="600">TradeFlow Finance (IRS 600)</option>
            <option value="820">AsiaReit Capital (IRS 820)</option>
            <option value="380">UrbanBridge Infra (IRS 380)</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="coverageAmount">Coverage Amount (USDT)</label>
          <input type="number" class="form-input" id="coverageAmount" value="15000" min="1" max="1000000" oninput="calculatePremium()" placeholder="Enter amount">
        </div>

        <div class="form-group">
          <label class="form-label" for="coverageDays">Duration (Days)</label>
          <input type="number" class="form-input" id="coverageDays" value="365" min="1" max="730" oninput="calculatePremium()" placeholder="365">
        </div>

        <div class="premium-display">
          <div class="premium-row">
            <span class="premium-label">Annual Premium</span>
            <span class="premium-value" id="premiumBps">696 bps (6.96%)</span>
          </div>
          <div class="premium-row">
            <span class="premium-label">You Pay</span>
            <span class="premium-value large" id="premiumAmount">$1,044.00</span>
          </div>
        </div>

        <button class="btn btn-primary" style="width:100%" onclick="showToast('Connect wallet to purchase coverage', 'info')">
          Purchase Coverage
        </button>

        <div class="soulbound-note">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
            <rect x="3" y="11" width="18" height="11" rx="3" fill="url(#verifyGrad)"/>
            <path d="M7 11V7a5 5 0 0110 0v4" stroke="url(#verifyGrad)" stroke-width="2"/>
          </svg>
          <span>You'll receive a <strong>Soulbound ProtectionCert NFT</strong> — Non-transferable</span>
        </div>
      </div>

      <!-- Protection Certificate -->
      <div class="card-dark cert-card reveal" id="cert">
        <div class="cert-header">
          <h4>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="8" r="6" fill="url(#goldGrad)"/>
              <path d="M8.21 13.89L7 23l5-3 5 3-1.21-9.12" fill="url(#goldGrad)" opacity="0.7"/>
            </svg>
            ProtectionCert #3
          </h4>
          <span class="badge badge-gold">ERC-721 + ERC-5192</span>
        </div>

        <div class="cert-grid">
          <div class="cert-field">
            <div class="cert-field-label">Issuer</div>
            <div class="cert-field-value">TradeFlow Finance</div>
          </div>
          <div class="cert-field">
            <div class="cert-field-label">Coverage</div>
            <div class="cert-field-value">$15,000</div>
          </div>
          <div class="cert-field">
            <div class="cert-field-label">Premium Paid</div>
            <div class="cert-field-value">$1,044</div>
          </div>
          <div class="cert-field">
            <div class="cert-field-label">Expires</div>
            <div class="cert-field-value">Mar 25, 2027</div>
          </div>
          <div class="cert-field">
            <div class="cert-field-label">Holder</div>
            <div class="cert-field-value" style="font-family:var(--font-mono);font-size:0.75rem">0xce22...42fb3</div>
          </div>
          <div class="cert-field">
            <div class="cert-field-label">Status</div>
            <div class="cert-field-value" style="color:var(--color-success)">Active</div>
          </div>
        </div>

        <div class="cert-soulbound">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
            <rect x="3" y="11" width="18" height="11" rx="2" fill="currentColor"/>
            <path d="M7 11V7a5 5 0 0110 0v4" stroke="currentColor" stroke-width="2"/>
          </svg>
          SOULBOUND &middot; Non-transferable &middot; ERC-5192 locked()
        </div>
      </div>
    </div>
  </div>
</div>

