<!-- ============================================================
     DEMO MODAL
     ============================================================ -->
<div class="modal-overlay" id="demoModal" onclick="if(event.target===this) closeDemo()">
  <div class="modal" role="dialog" aria-modal="true" aria-label="CoverFi Protocol Demo">
    <button class="modal-close" onclick="closeDemo()">&times;</button>

    <h3 id="demoTitle">Full Protocol Demo</h3>
    <p id="demoSubtitle">Simulating the complete CoverFi lifecycle on BSC Testnet.</p>

    <div class="demo-steps">
      <div class="demo-step-dot active" id="dot1"></div>
      <div class="demo-step-bar" id="bar1"></div>
      <div class="demo-step-dot" id="dot2"></div>
      <div class="demo-step-bar" id="bar2"></div>
      <div class="demo-step-dot" id="dot3"></div>
    </div>

    <div class="demo-content" id="demoContent">
      <h4>Step 1: Issuer Registration & Activation</h4>
      <div class="detail-row">
        <span class="detail-label">Action</span>
        <span class="detail-value">Register TradeFlow Finance</span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Bond</span>
        <span class="detail-value">5 BNB</span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Attestations</span>
        <span class="detail-value">3 of 3 (Custodian, Legal, Auditor)</span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Initial IRS</span>
        <span class="detail-value" style="color:var(--gold)">600</span>
      </div>
    </div>

    <button class="btn btn-primary" style="width:100%" id="demoNextBtn" onclick="nextDemoStep()">
      Execute Step 1 &rarr;
    </button>
  </div>
</div>

<!-- ============================================================
     TOAST
     ============================================================ -->
<div class="toast" id="toast" role="alert" aria-live="assertive">
  <div class="toast-icon" id="toastIcon">&#10003;</div>
  <span id="toastText">Transaction confirmed</span>
</div>

<!-- ============================================================
     JAVASCRIPT
     ============================================================ -->
<script>
// ---- Reduced motion check ----
const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

// ---- NAV: transparent to white blur on scroll ----
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  if (window.scrollY > 50) {
    nav.classList.add('scrolled');
  } else {
    nav.classList.remove('scrolled');
  }
}, { passive: true });

// ---- Mobile nav toggle ----
function toggleNav() {
  document.getElementById('navLinks').classList.toggle('open');
}

// ---- 4-Layer Parallax in hero (rAF) ----
const parallaxEls = document.querySelectorAll('.parallax-bg[data-speed]');
let ticking = false;
function updateParallax() {
  if (REDUCED) return;
  const y = window.scrollY;
  parallaxEls.forEach(el => {
    const speed = parseFloat(el.dataset.speed);
    el.style.transform = el.style.transform.replace(/translateY\([^)]*\)/, '') || '';
    el.style.transform += ' translateY(' + (y * speed) + 'px)';
  });
  ticking = false;
}
window.addEventListener('scroll', () => {
  if (!ticking) {
    requestAnimationFrame(updateParallax);
    ticking = true;
  }
}, { passive: true });

// ---- Scroll Reveal with stagger per-section ----
const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      // Find all reveal children within this section context
      const parent = entry.target.closest('.features-grid, .how-grid, .stats-grid, .dashboard, .dashboard-col-left, .dashboard-col-center, .dashboard-side');
      if (parent) {
        const siblings = parent.querySelectorAll('.reveal');
        let idx = 0;
        siblings.forEach(sib => {
          if (!sib.classList.contains('visible')) {
            setTimeout(() => sib.classList.add('visible'), idx * 100);
            idx++;
          }
        });
      }
      clearTimeout(entry.target._revealTimeout);
      const delay = entry.target.dataset.delay || 0;
      setTimeout(() => {
        entry.target.classList.add('visible');
      }, delay);
      revealObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0.15 });

document.querySelectorAll('.reveal').forEach((el, i) => {
  revealObserver.observe(el);
  // Fallback: ensure visibility after timeout
  el._revealTimeout = setTimeout(() => {
    if (!el.classList.contains('visible')) {
      el.classList.add('visible');
    }
  }, 3000 + i * 50);
});

// ---- 3D Card Tilt on mousemove ----
document.querySelectorAll('.tilt-card').forEach(card => {
  card.addEventListener('mousemove', (e) => {
    if (REDUCED) return;
    const rect = card.getBoundingClientRect();
    const x = (e.clientX - rect.left) / rect.width - 0.5;
    const y = (e.clientY - rect.top) / rect.height - 0.5;
    card.style.transform = 'perspective(800px) rotateX(' + (-y * 8) + 'deg) rotateY(' + (x * 8) + 'deg) translateY(-4px) scale(1.01)';
  });
  card.addEventListener('mouseleave', () => {
    card.style.transform = '';
  });
});

// ---- Count-up Animation ----
function animateCount(el, target, prefix, suffix, duration) {
  prefix = prefix || '';
  suffix = suffix || '';
  duration = duration || 2000;
  const startTime = performance.now();
  function update(currentTime) {
    const elapsed = currentTime - startTime;
    const progress = Math.min(elapsed / duration, 1);
    // Ease-out cubic
    const eased = 1 - Math.pow(1 - progress, 3);
    const current = Math.floor(target * eased);
    el.textContent = prefix + current.toLocaleString() + suffix;
    if (progress < 1) requestAnimationFrame(update);
  }
  requestAnimationFrame(update);
}

// ---- IRS Gauge Animation (scroll-driven) ----
function animateGauge(score) {
  const arc = document.getElementById('irsArc');
  if (!arc) return;
  const circumference = 2 * Math.PI * 50; // ~314
  const pct = score / 1000;
  const offset = circumference * (1 - pct * 0.6);
  arc.style.transition = 'stroke-dashoffset 1.5s ' + (REDUCED ? 'ease' : 'cubic-bezier(0.4, 1.35, 0.5, 0.97)');
  arc.style.strokeDashoffset = offset;
}

// ---- Pool ratio bar fill on scroll ----
function animatePoolBar() {
  const bar = document.getElementById('poolRatioBar');
  if (!bar) return;
  const senior = bar.querySelector('.pool-ratio-senior');
  const junior = bar.querySelector('.pool-ratio-junior');
  if (senior) senior.style.width = '70%';
  if (junior) junior.style.width = '30%';
}

// ---- IRS dimension bars fill on scroll ----
function animateDimBars() {
  document.querySelectorAll('.irs-dim-fill').forEach(fill => {
    const w = fill.dataset.width;
    if (w) fill.style.width = w + '%';
  });
}

// Combined scroll-driven animations
const scrollAnimObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const id = entry.target.id;
      if (id === 'irs') {
        animateGauge(600);
        animateDimBars();
      }
      if (id === 'pool') {
        animatePoolBar();
      }
      scrollAnimObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0.2 });

const irsEl = document.getElementById('irs');
const poolEl = document.getElementById('pool');
if (irsEl) scrollAnimObserver.observe(irsEl);
if (poolEl) scrollAnimObserver.observe(poolEl);

// ---- Premium Calculator ----
function calculatePremium() {
  const irs = parseInt(document.getElementById('issuerSelect').value) || 600;
  const amount = parseFloat(document.getElementById('coverageAmount').value) || 0;
  const days = parseInt(document.getElementById('coverageDays').value) || 365;
  const bps = 1600 * Math.exp(-0.001386 * irs);
  const annualRate = bps / 10000;
  const premium = amount * annualRate * (days / 365);
  document.getElementById('premiumBps').textContent =
    Math.round(bps) + ' bps (' + (annualRate * 100).toFixed(2) + '%)';
  document.getElementById('premiumAmount').textContent =
    '$' + premium.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
}

// ---- Wallet Connection ----
async function connectWallet() {
  const btn = document.getElementById('connectBtn');
  if (typeof window.ethereum !== 'undefined') {
    try {
      btn.disabled = true;
      btn.textContent = 'Connecting...';
      const accounts = await window.ethereum.request({ method: 'eth_requestAccounts' });
      const addr = accounts[0];
      btn.textContent = addr.slice(0, 6) + '...' + addr.slice(-4);
      btn.classList.remove('btn-primary');
      btn.classList.add('btn-secondary');
      btn.style.borderColor = 'var(--border-light)';
      btn.style.color = 'var(--text-dark)';
      showToast('Wallet connected: ' + addr.slice(0, 8) + '...', 'success');
      window.ethereum.on('accountsChanged', (accounts) => {
        if (accounts.length === 0) {
          btn.textContent = 'Connect Wallet';
          btn.classList.remove('btn-secondary-dark');
          btn.classList.add('btn-primary');
          btn.disabled = false;
        } else {
          btn.textContent = accounts[0].slice(0,6) + '...' + accounts[0].slice(-4);
        }
      });
    } catch (e) {
      btn.disabled = false;
      btn.textContent = 'Connect Wallet';
      showToast('Connection rejected', 'error');
    }
  } else {
    showToast('Install MetaMask to connect', 'error');
  }
}

// ---- Toast Notifications ----
let toastTimer;
function showToast(message, type) {
  clearTimeout(toastTimer);
  type = type || 'info';
  const toast = document.getElementById('toast');
  const icon = document.getElementById('toastIcon');
  const text = document.getElementById('toastText');
  text.textContent = message;
  if (type === 'success') {
    icon.textContent = '\u2713';
    icon.style.background = 'var(--color-success-dim)';
    icon.style.color = 'var(--color-success)';
  } else if (type === 'error') {
    icon.textContent = '\u2715';
    icon.style.background = 'var(--color-danger-dim)';
    icon.style.color = 'var(--color-danger)';
  } else {
    icon.textContent = '\u2139';
    icon.style.background = 'rgba(30,123,255,0.12)';
    icon.style.color = 'var(--color-pool)';
  }
  toast.classList.add('show');
  toastTimer = setTimeout(() => toast.classList.remove('show'), 3500);
}

// ---- Demo Modal ----
let demoStep = 1;
let prevFocusBeforeModal;

function startDemo() {
  demoStep = 1;
  prevFocusBeforeModal = document.activeElement;
  updateDemoUI();
  document.getElementById('demoModal').classList.add('active');
  const closeBtn = document.querySelector('#demoModal .modal-close');
  if (closeBtn) closeBtn.focus();
}

function closeDemo() {
  document.getElementById('demoModal').classList.remove('active');
  if (prevFocusBeforeModal) prevFocusBeforeModal.focus();
}

function nextDemoStep() {
  const demoBtn = document.getElementById('demoNextBtn');
  demoBtn.disabled = true;
  setTimeout(() => { demoBtn.disabled = false; }, 600);
  if (demoStep >= 3) {
    closeDemo();
    showToast('Demo complete! All 3 transactions simulated.', 'success');
    return;
  }
  document.getElementById('dot' + demoStep).classList.remove('active');
  document.getElementById('dot' + demoStep).classList.add('done');
  document.getElementById('bar' + demoStep).classList.add('done');
  demoStep++;
  updateDemoUI();
}

function updateDemoUI() {
  const content = document.getElementById('demoContent');
  const btn = document.getElementById('demoNextBtn');
  const dot = document.getElementById('dot' + demoStep);
  dot.classList.add('active');

  if (demoStep === 1) {
    content.innerHTML = '<h4>Step 1: Issuer Registration & Activation</h4>' +
      '<div class="detail-row"><span class="detail-label">Action</span><span class="detail-value">Register TradeFlow Finance</span></div>' +
      '<div class="detail-row"><span class="detail-label">Bond</span><span class="detail-value">5 BNB</span></div>' +
      '<div class="detail-row"><span class="detail-label">Attestations</span><span class="detail-value">3 of 3 (Custodian, Legal, Auditor)</span></div>' +
      '<div class="detail-row"><span class="detail-label">Initial IRS</span><span class="detail-value" style="color:var(--gold)">600</span></div>';
    btn.textContent = 'Execute Step 1 \u2192';
  } else if (demoStep === 2) {
    content.innerHTML = '<h4>Step 2: Underwriter Deposits & Coverage</h4>' +
      '<div class="detail-row"><span class="detail-label">Senior Deposit</span><span class="detail-value">$7,000 USDT \u2192 7000 srCVR</span></div>' +
      '<div class="detail-row"><span class="detail-label">Junior Deposit</span><span class="detail-value">$3,000 USDT \u2192 3000 jrCVR</span></div>' +
      '<div class="detail-row"><span class="detail-label">Pool Total</span><span class="detail-value">$15,000 (Bond + Sr + Jr)</span></div>' +
      '<div class="detail-row"><span class="detail-label">Coverage</span><span class="detail-value">$15,000 \u2192 ProtectionCert #3</span></div>';
    btn.textContent = 'Execute Step 2 \u2192';
  } else if (demoStep === 3) {
    content.innerHTML = '<h4>Step 3: Default & Payout</h4>' +
      '<div class="detail-row"><span class="detail-label">Default Type</span><span class="detail-value" style="color:var(--color-danger)">MISAPPROPRIATION</span></div>' +
      '<div class="detail-row"><span class="detail-label">Attestors</span><span class="detail-value">2/3 confirmed (Custodian + Auditor)</span></div>' +
      '<div class="detail-row"><span class="detail-label">Payout</span><span class="detail-value" style="color:var(--color-success)">$15,000 USDT to investor</span></div>' +
      '<div class="detail-row"><span class="detail-label">SubrogationNFT</span><span class="detail-value">#1 minted to Foundation</span></div>' +
      '<div class="detail-row"><span class="detail-label">IRS After</span><span class="detail-value" style="color:var(--color-danger)">0</span></div>';
    btn.textContent = 'Execute Step 3 & Finish \u2713';
  }
}

// ---- Smooth scroll for nav links ----
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', (e) => {
    e.preventDefault();
    const target = document.querySelector(a.getAttribute('href'));
    if (target) {
      const offset = 72;
      window.scrollTo({
        top: target.offsetTop - offset - 16,
        behavior: 'smooth'
      });
    }
    document.getElementById('navLinks').classList.remove('open');
  });
});

// ---- Escape key to close modal (Issue 1) ----
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeDemo();
});

// ---- Close mobile nav on outside click (Issue 6) ----
document.addEventListener('click', (e) => {
  const nav = document.getElementById('navLinks');
  const toggle = document.getElementById('navToggle');
  if (nav.classList.contains('open') && !nav.contains(e.target) && !toggle.contains(e.target)) {
    nav.classList.remove('open');
  }
});

// ---- Scroll spy for active nav link (Issue 11) ----
const navSections = ['hero', 'issuers', 'pool', 'how-it-works', 'dashboard'];
const navSpyObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
      const id = entry.target.id;
      const link = document.querySelector('.nav-links a[href="#' + id + '"]');
      if (link) link.classList.add('active');
    }
  });
}, { threshold: 0.3, rootMargin: '-80px 0px 0px 0px' });

navSections.forEach(id => {
  const el = document.getElementById(id);
  if (el) navSpyObserver.observe(el);
});

// ---- Init ----
calculatePremium();
</script>

</body>
</html>
