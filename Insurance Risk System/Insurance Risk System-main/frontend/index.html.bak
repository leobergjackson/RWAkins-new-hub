                <div class="irs-dim-bar"><div class="irs-dim-fill" data-width="60" style="background:var(--color-verify)"></div></div>
                <span class="irs-dim-value">30 / 50</span>
              </div>
            </div>
          </div>
        </div>

        <div class="irs-formula">
          <div class="irs-formula-title">Annual Premium Formula</div>
          <code>1600 &times; e<sup>(-0.001386 &times; IRS)</sup></code>
          <span class="result">= 696 bps (6.96%)</span>
        </div>
