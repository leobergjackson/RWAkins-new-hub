            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="10" fill="url(#goldGrad)"/>
              <path d="M12 6v6l4 2" stroke="#0a0a0a" stroke-width="2" stroke-linecap="round"/>
            </svg>
            IRS Oracle
          </h3>
          <span class="badge badge-green">Live</span>
        </div>

        <div class="irs-gauge-container">
          <div class="irs-gauge">
            <svg viewBox="0 0 120 120">
              <circle cx="60" cy="60" r="50" stroke="rgba(255,255,255,0.06)" stroke-width="8" fill="none"/>
              <circle cx="60" cy="60" r="50" stroke="url(#irsArcGrad)" stroke-width="8" fill="none"
                      stroke-dasharray="314" stroke-linecap="round"
                      style="stroke-dashoffset: 314"
                      id="irsArc"/>
            </svg>
            <div class="irs-gauge-value">
              <span class="irs-gauge-number" id="irsScoreDisplay">600</span>
              <span class="irs-gauge-label">/ 1000</span>
            </div>
