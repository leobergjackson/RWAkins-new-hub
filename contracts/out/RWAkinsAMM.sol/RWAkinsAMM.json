"name\":\"\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"tokenIn\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"amountIn\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"minOut\",\"type\":\"uint256\"},{\"internalType\":\"address\",\"name\":\"to\",\"type\":\"address\"}],\"name\":\"swap\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"amountOut\",\"type\":\"uint256\"}],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"targetPriceE18\",\"type\":\"uint256\"}],\"name\":\"syncToPrice\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"usdy\",\"outputs\":[{\"internalType\":\"contract IERC20Mintable\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"kind\":\"dev\",\"methods\":{},\"title\":\"RWAkinsAMM\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"addLiquidity(uint256,uint256)\":{\"notice\":\"Seed/add liquidity. Pulls both tokens from the owner.\"},\"getAmountOut(address,uint256)\":{\"notice\":\"Quote how much `tokenIn`=amountIn buys of the other token, after fee.\"},\"spotPriceE18()\":{\"notice\":\"Spot price of 1 mETH in USDY units (18 decimals) = reserveUsdy/reserveMeth.\"},\"swap(address,uint256,uint256,address)\":{\"notice\":\"Swap `amountIn` of `tokenIn` for the other token, sent to `to`.         Pulls `tokenIn` from msg.sender (must approve first). Real x*y=k with         a 0.3% fee \\u2192 real slippage. Reverts if output < minOut.\"},\"syncToPrice(uint256)\":{\"notice\":\"Anchor the pool's spot price to the live market (what an arbitrageur         does on a real DEX). Keeps the mETH reserve fixed and mints/burns the         USDY reserve so spotPrice == targetPriceE18. Owner-only (agent key).         Swaps still pay real slippage around this anchored price.\"}},\"notice\":\"A minimal Uniswap-V2-style constant-product (x*y=k) AMM for the USDY/mETH         pair on Mantle Sepolia. This is what makes the RWAkins rebalance a REAL         on-chain swap: the vault routes USDY<->mETH through swap() here, so every         rebalance pays a real 0.3% fee and takes real price impact / slippage from         the pool reserves \\u2014 not a frozen oracle constant. The spot price is read         straight off the reserves (real price discovery).         The tokens themselves are still testnet mocks (real Ondo USDY / Mantle         mETH are mainnet-only, KYC-gated), so the owner \\u2014 the AI-CFO agent key \\u2014         keeps the pool anchored to the live market via syncToPrice(), exactly the         job arbitrageurs do on a real DEX. The swap mechanics are fully real.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/RWAkinsAMM.sol\":\"RWAkinsAMM\"},\"evmVersion\":\"cancun\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[]},\"sources\":{\"src/RWAkinsAMM.sol\":{\"keccak256\":\"0x57cf6cbd819af7cf5cad64ba7df0f1a3d885c7173aee9bd57f812ea04844464c\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://6d8a91da72325280994b7e1e0d2dcf439149dc30c5141f86ecedd22e04ae7ccc\",\"dweb:/ipfs/QmRZCUVhiCJ1d9TEjZatfY8v6pVBFxRLs7aj6ningjjohv\"]}},\"version\":1}","metadata":{"compiler":{"version":"0.8.24+commit.e11b9ed9"},"language":"Solidity","output":{"abi":[{"inputs":[{"internalType":"address","name":"_usdy","type":"address"},{"internalType":"address","name":"_meth","type":"address"}],"stateMutability":"nonpayable","type":"constructor"},{"inputs":[{"internalType":"uint256","name":"usdyAmount","type":"uint256","indexed":false},{"internalType":"uint256","name":"methAmount","type":"uint256","indexed":false}],"type":"event","name":"LiquidityAdded","anonymous":false},{"inputs":[{"internalType":"address","name":"caller","type":"address","indexed":true},{"internalType":"address","name":"tokenI