{
  "manifest_version": 3,
  "name": "Colibrí — Send Money Home",
  "description": "Colibrí companion — AI-powered USD→MXN remittances on Arbitrum + Base with a Bitso peso off-ramp.",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage", "alarms", "notifications"],
  "host_permissions": ["https://rumble.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://rumble.com/*", "https://*.rumble.com/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}
