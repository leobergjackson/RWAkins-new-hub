# AeroFyta Agent — Environment Variables
# Copy this file to .env and fill in values as needed.
# All variables are OPTIONAL — the agent works with sensible defaults.

# ╔══════════════════════════════════════════════════════════════════╗
# ║  GET A FREE API KEY: Visit https://console.groq.com             ║
# ║  Free tier, no credit card required.                            ║
# ║  Without this key, the agent runs in rule-based mode only       ║
# ║  (no LLM reasoning).                                           ║
# ╚══════════════════════════════════════════════════════════════════╝

# WDK seed phrase (auto-generated if not provided)
# WDK_SEED=your twelve word seed phrase here

# Optional — encrypts seed phrase at rest with AES-256-GCM
# SEED_ENCRYPTION_KEY=

# Groq API key for LLM reasoning (primary provider — free tier)
# GROQ_API_KEY=gsk_your_groq_api_key_here

# Gemini API key for LLM reasoning (secondary fallback — free tier)
# GEMINI_API_KEY=your_gemini_api_key_here

# Ollama LLM (legacy, no longer primary — Groq is used instead)
# OLLAMA_HOST=http://localhost:11434

# Server port (default: 3001)
# PORT=3001

# Telegram bot token for Telegram tipping commands
# TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ERC-4337 gasless transactions (requires Pimlico API key)
# ERC4337_BUNDLER_URL=https://api.pimlico.io/v2/11155111/rpc?apikey=YOUR_KEY
# ERC4337_PAYMASTER_URL=https://api.pimlico.io/v2/11155111/rpc?apikey=YOUR_KEY

# Autonomous mode — agent runs ReAct loop without human input (default: true)
# Set to false to disable auto-start; use POST /api/agent/loop/start manually
AUTONOMOUS_MODE=true

# Loop interval in milliseconds (default: 60000 = 60 seconds)
# LOOP_INTERVAL_MS=60000

# Demo mode — pre-seeds dashboard with sample data (default: true)
# Set to false for production use
# DEMO_MODE=true

# API key for authenticating sensitive endpoints (wallet, tip)
# If not set, endpoints are open (suitable for local dev only)
# API_KEY=your-secret-api-key

# AEROFYTA_API_KEY — protects write endpoints (POST/PUT/DELETE/PATCH).
# Leave empty for open access (hackathon demo mode).
# When set, all write requests must include X-API-Key header or ?apiKey query param.
AEROFYTA_API_KEY=

# CORS origin for dashboard (default: http://localhost:5173)
# CORS_ORIGIN=http://localhost:5173

# Real events — fetch Rumble RSS feeds instead of pure simulation (default: false)
# When true, the event simulator fetches RSS from registered creators' channels
# and generates events from real video uploads. Falls back to simulation if RSS fails.
# USE_REAL_EVENTS=true

# YouTube Data API v3 key (free, 10k quota/day) — get from console.cloud.google.com
# YOUTUBE_API_KEY=

# Persistence mode — Options: json (default), sqlite, postgres
# - json: Zero-dependency file-based (hackathon-ready, no setup)
# - sqlite: Embedded SQL database with WAL mode (requires better-sqlite3)
# - postgres: Production-grade PostgreSQL with JSONB + connection pooling (requires pg)
PERSISTENCE_MODE=json

# PostgreSQL connection string (required if PERSISTENCE_MODE=postgres)
# DATABASE_URL=postgresql://user:password@localhost:5432/aerofyta

# Custom RPC endpoints (free public defaults are used if not set)
# ETH_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
# ETH_MAINNET_RPC=https://cloudflare-eth.com
